# Core
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
FRONTEND_URL=https://tu-frontend.com
GEMINI_API_KEY=tu_gemini_api_key
JWT_SECRET=tu_jwt_secret_largo_min_32_chars

# 2FA / TOTP (debe coincidir con el firmware ESP32)
TWO_FACTOR_REQUIRED=true
DEVICE_SERIAL=ESP32-DEMO-001
TOTP_SECRET_GLOBAL=Q3VIRM3IWNOSJGJXLSMNOFZXULFGTHAK
TOTP_DIGITS=6
TOTP_PERIOD_SECONDS=60
TOTP_VALID_WINDOW=1
TWO_FACTOR_TMP_TOKEN_EXPIRE_MINUTES=5
TWO_FACTOR_MAX_ATTEMPTS=5
DEVICE_NOTIFY_PATTERN=TRIPLE

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_cloudinary_api_key
CLOUDINARY_API_SECRET=tu_cloudinary_api_secret
CLOUDINARY_FOLDER=tu_folder

# Option A: SMTP (requires paid Render if using smtp ports 25/465/587)
SENDER_EMAIL=tu_correo@gmail.com
SENDER_PASSWORD=tu_app_password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_TIMEOUT=12
MAIL_FROM_NAME=Grupo 5

# Option B: Resend API (recommended on Render Free)
MAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=onboarding@resend.dev
# MAIL_FROM_NAME can be reused from above
